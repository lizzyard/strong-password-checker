import re
# password must be 8 characters long containing both uppercase and lowercase letters
# has at least one digit

passwords = (
    # Valid passwords
    'Hello123',
    'Password1',
    'MyDog2025',
    '0livia!2006',

    # Too short
    'Hi123',
    'Abc1',

    # No uppercase
    'hello123',
    'password1',

    # No lowercase
    'HELLO123',
    'PASSWORD1',

    # No digit
    'HelloWorld',
    'Password',

    # Missing multiple requirements
    'hello',
    '12345678',
    'ABCDEFGH',

    # Edge cases
    'Aaaaaaa1',     # exactly 8 chars
    'Z1zzzzzz',     # exactly 8 chars
    'A1bcdefg',     # exactly 8 chars
)



def is_strongpassword(string):
    return bool(
    len(string) >= 8
    and re.search(r'[A-Z]', string)
    and re.search(r'[a-z]', string)
    and re.search(r'[0-9]', string)
)


for password in passwords:
    print(password, is_strongpassword(password))
